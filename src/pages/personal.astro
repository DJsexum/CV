---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Información Personal | Juan Cabrera">
  <div class="mx-auto max-w-4xl px-6 py-20 flex items-center min-h-[80vh]">
    <section class="glass-card w-full p-10 md:p-16 relative overflow-hidden">
      <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-blue-500/10 blur-[100px] rounded-full"></div>
      
      <header class="mb-16">
        <h2 class="text-cyan-500 font-black text-xs uppercase tracking-[0.5em] mb-4 text-center md:text-left">Ficha de Identidad</h2>
        <h1 class="text-5xl md:text-6xl font-black uppercase tracking-tighter text-center md:text-left">Datos <span class="text-gradient">Personales</span></h1>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="space-y-10">
          <div>
            <h3 class="text-xs font-black uppercase tracking-widest opacity-40 mb-4 text-cyan-500">Ubicación</h3>
            <p class="text-2xl font-bold">Ceres, Santa Fe <br/> <span class="text-lg font-medium opacity-60">Argentina</span></p>
          </div>
          <div>
            <h3 class="text-xs font-black uppercase tracking-widest opacity-40 mb-4 text-cyan-500">Contacto Directo</h3>
            <p class="text-lg font-bold">juancruzcabrerasocin@gmail.com</p>
            <p class="text-lg font-bold mt-2">+54 3491687149</p>
          </div>
        </div>

        <div class="bg-slate-900/5 dark:bg-white/5 rounded-[2.5rem] p-8 border border-white/10 shadow-inner">
          <h3 class="text-xs font-black uppercase tracking-widest opacity-40 mb-8 text-center">Fortalezas Principales</h3>
          <div class="grid grid-cols-1 gap-4">
            {["Especialista en Excel", "Seguridad en Redes", "Arquitectura POO", "Redacción Técnica"].map(item => (
              <div class="flex items-center gap-4 bg-white/5 dark:bg-black/20 p-4 rounded-2xl border border-white/5 hover:border-cyan-500/50 transition-all group">
                <div class="w-2 h-2 rounded-full bg-cyan-500 shadow-[0_0_10px_rgba(34,211,238,1)] group-hover:scale-150 transition-transform"></div>
                <span class="text-sm font-bold uppercase tracking-tight">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-16 flex justify-center">
        <a href="/" class="text-xs font-black uppercase tracking-[0.3em] py-4 px-10 border-b-2 border-cyan-500 hover:bg-cyan-500/10 transition-all flex items-center gap-3">
          <span>←</span> Regresar al Inicio
        </a>
      </div>
    </section>
  </div>
</Layout>