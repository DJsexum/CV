---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Información Personal | Juan Cruz Cabrera">
  <div class="mx-auto max-w-6xl px-6 h-screen flex flex-col justify-evenly py-8">
    
    <section class="cv-card p-10 md:p-14 relative overflow-hidden">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-500/10 blur-[120px] rounded-full"></div>
      <div class="relative z-10">
        <p class="text-blue-600 font-black tracking-[0.5em] text-sm uppercase mb-4">Detalles del Estudiante</p>
        <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-none mb-6 text-main-title uppercase">
          INFORMACIÓN <br/> <span class="text-blue-600">PERSONAL</span>
        </h1>
        <p class="text-2xl opacity-80 max-w-3xl font-medium leading-relaxed">
          Estudiante de la <span class="font-bold text-main-title">UTN</span> en Ceres, Santa Fe. Tecnicatura Universitaria en Programación (TUP).
        </p>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">Contacto Directo</h2>
        <div class="space-y-6">
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">Ubicación</h3>
            <p class="text-base opacity-70">Ceres, Santa Fe, Argentina</p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">Correo Electrónico</h3>
            <p class="text-base opacity-70">juancruzcabrerasocin@gmail.com</p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">Teléfono</h3>
            <p class="text-base opacity-70">+54 3491687149</p>
          </div>
        </div>
      </article>

      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">Fortalezas Clave</h2>
        <div class="space-y-6">
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">Excel Avanzado</h3>
            <p class="text-base opacity-70">Gestión de datos y herramientas de oficina.</p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">Seguridad</h3>
            <p class="text-base opacity-70">Telecomunicaciones y ciberseguridad.</p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">Arquitectura</h3>
            <p class="text-base opacity-70">Programación Orientada a Objetos (POO).</p>
          </div>
        </div>
      </article>
    </div>

    <div class="flex justify-center md:justify-start">
      <a href="/" class="px-12 py-6 bg-slate-900 text-white font-black rounded-[2rem] hover:scale-105 transition-all uppercase text-sm tracking-widest shadow-2xl">
        ← Volver al Portfolio
      </a>
    </div>
  </div>
</Layout>