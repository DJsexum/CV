---
import Layout from '../layouts/Layout.astro';
// Importamos la interfaz para asegurar que los datos sean correctos
import type { DatosContacto } from '../core/interfaces/cv.interfaces.ts';

const misDatos: DatosContacto = 
{
    ubicacion: "Ceres, Santa Fe, Argentina",
    correo: "juancruzcabrerasocin@gmail.com",
    habilidades: ["C", "Java", "TypeScript", "Markdown"],
    formacion: ["Excel", "Seguridad en Telecomunicaciones", "Digitalización"]
};
---

<Layout title="CV - Información Personal">
    <div class="mx-auto min-h-screen max-w-4xl px-6 py-14 sm:px-8">
        <section class="rounded-3xl border border-slate-700 bg-slate-950/90 p-8 shadow-lg shadow-slate-950/50">
            
            <header class="mb-8 border-b border-slate-800 pb-8">
                <p class="text-sm uppercase tracking-[0.3em] text-cyan-400 font-bold">Información Personal</p>
                <h1 class="mt-3 text-4xl font-bold text-white uppercase tracking-tight">Juan Cruz Cabrera</h1>
                <p class="mt-4 max-w-2xl text-slate-300">
                    Estudiante de programación con enfoque en arquitecturas modernas y seguridad.
                </p>
            </header>

            <div class="grid gap-6 lg:grid-cols-2">
                <article class="rounded-3xl bg-slate-900/80 p-6 border border-slate-800">
                    <h2 class="text-xl font-bold text-white border-b border-cyan-500/30 pb-2 italic">Datos de contacto</h2>
                    <ul class="mt-4 space-y-3 text-slate-300">
                        <li><strong class="text-cyan-400 font-bold">Ubicación:</strong> {misDatos.ubicacion}</li>
                        <li><strong class="text-cyan-400 font-bold">Correo:</strong> {misDatos.correo}</li>
                    </ul>
                </article>

                <article class="rounded-3xl bg-slate-900/80 p-6 border border-slate-800">
                    <h2 class="text-xl font-bold text-white border-b border-cyan-500/30 pb-2 italic">Fortalezas</h2>
                    <ul class="mt-4 space-y-2 text-slate-300">
                        {misDatos.formacion.map((item) => (
                            <li class="flex items-center">
                                <span class="text-cyan-500 mr-2">▹</span> {item}
                            </li>
                        ))}
                    </ul>
                </article>
            </div>

            <div class="mt-10 flex justify-start">
                <a href="/" class="inline-flex items-center justify-center rounded-full bg-cyan-500 px-8 py-3 text-sm font-bold text-slate-950 transition hover:bg-cyan-400 shadow-lg shadow-cyan-500/20">
                    ← VOLVER AL CV
                </a>
            </div>

        </section>
    </div>
</Layout>