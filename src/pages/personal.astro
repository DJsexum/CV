---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Información Personal | Juan Cruz Cabrera">
  <div class="mx-auto max-w-6xl px-6 page-container">
    <section class="cv-card p-10 md:p-14 relative overflow-hidden">
      <div
        class="absolute -top-40 -right-40 w-96 h-96 bg-blue-600/10 blur-[120px] rounded-full"
      >
      </div>
      <div class="relative z-10">
        <p
          class="text-blue-500 font-black tracking-[0.5em] text-xs uppercase mb-4"
        >
          Detalles del Estudiante
        </p>
        <h1
          class="text-6xl md:text-8xl font-black tracking-tighter leading-none mb-8 text-main-title uppercase"
        >
          INFORMACIÓN <br />
          <span class="text-blue-500">PERSONAL</span>
        </h1>
        <p class="text-xl opacity-80 max-w-2xl font-medium leading-relaxed">
          Estudiante de la <span class="font-bold text-main-title">UTN</span> en Ceres.
          Tecnicatura Universitaria en Programación (TUP).
        </p>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">
          Contacto Directo
        </h2>
        <div class="space-y-6">
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">
              Ubicación
            </h3>
            <p class="text-base opacity-70 italic">
              Ceres, Santa Fe, Argentina
            </p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">
              Correo
            </h3>
            <p class="text-sm opacity-70 italic">
              juancruzcabrerasocin@gmail.com
            </p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">
              Teléfono
            </h3>
            <p class="text-base opacity-70 italic">+54 3491687149</p>
          </div>
        </div>
      </article>

      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">
          Fortalezas
        </h2>
        <div class="space-y-6">
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">
              Excel Avanzado
            </h3>
            <p class="text-base opacity-70 italic">
              Gestión de datos corporativos.
            </p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">
              Seguridad
            </h3>
            <p class="text-base opacity-70 italic">
              Ciberseguridad en Telecomunicaciones.
            </p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="font-black uppercase text-main-title italic text-lg">
              POO
            </h3>
            <p class="text-base opacity-70 italic">
              Arquitectura sólida en Java/Python.
            </p>
          </div>
        </div>
      </article>
    </div>

    <div class="flex justify-center md:justify-start">
      <a href="/" class="btn-primary">← Volver al Portfolio</a>
    </div>
  </div>
</Layout>