---
import Layout from '../layouts/Layout.astro';
import Habilidades from '../components/habilidades.svelte';
import { Image } from 'astro:assets';

const habilidadesTecnicas: string[] = ["ASTRO", "TAILWIND", "SVELTE", "TYPESCRIPT", "JAVA", "KALI LINUX"];
---

<Layout title="Juan Cruz Cabrera | Portfolio">
  <div class="mx-auto max-w-6xl px-6 py-20">
    
    <section class="glass-card p-12 md:p-20 relative overflow-hidden mb-12">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-cyan-500/20 blur-[120px] rounded-full"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row items-center gap-16">
        <div class="relative">
          <div class="absolute inset-0 bg-cyan-400 blur-3xl opacity-30 animate-pulse"></div>
          <Image 
            src="/juan-cabrera.jpg" 
            alt="Juan Cruz" 
            width={220} 
            height={220} 
            class="relative rounded-[3rem] border-2 border-white/20 rotate-3 hover:rotate-0 transition-transform duration-500 shadow-2xl"
          />
        </div>

        <div class="flex-1 text-center md:text-left">
          <p class="text-cyan-500 font-black tracking-[0.5em] text-xs uppercase mb-4">Desarrollador de Software</p>
          <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-none mb-6 text-slate-900 dark:text-white">
            JUAN CRUZ <br/> <span class="text-gradient">CABRERA</span>
          </h1>
          <p class="text-xl opacity-70 max-w-xl font-medium leading-relaxed">
            Especializado en arquitecturas modernas con <span class="text-cyan-500 font-bold">Astro</span> y ciberseguridad. Estudiante de la <span class="font-bold">UTN</span> transformando código en soluciones reales.
          </p>
        </div>
      </div>

      <div class="mt-16 flex flex-wrap gap-4 justify-center md:justify-start">
        <Habilidades habilidades={habilidadesTecnicas} client:load />
      </div>
      
      <div class="mt-12 flex flex-wrap gap-6 justify-center md:justify-start">
        <a href="/personal" class="px-10 py-5 bg-cyan-600 hover:bg-cyan-500 text-white font-black rounded-2xl transition-all hover:scale-105 shadow-xl shadow-cyan-500/20 uppercase text-xs tracking-[0.2em]">
          Información Personal
        </a>
        
        <a href="https://github.com/DJsexum" target="_blank" class="flex items-center gap-3 px-10 py-5 bg-slate-800 hover:bg-slate-700 text-white font-black rounded-2xl transition-all hover:scale-105 shadow-xl uppercase text-xs tracking-[0.2em]">
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Mi GitHub
        </a>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <article class="glass-card p-10">
        <h2 class="text-3xl font-black uppercase mb-6 tracking-tight text-cyan-600 dark:text-cyan-400">Proyectos y Experiencia</h2>
        <div class="space-y-6">
          <div class="relative pl-6 border-l-2 border-cyan-500/20">
            <h3 class="text-lg font-bold uppercase">TechStore UTN</h3>
            <p class="text-sm opacity-60">Desarrollo y normalización de bases de datos SQL.</p>
          </div>
          <div class="relative pl-6 border-l-2 border-cyan-500/20">
            <h3 class="text-lg font-bold uppercase">LaMasita</h3>
            <p class="text-sm opacity-60">Automatización de mensajes de WhatsApp con Python.</p>
          </div>
        </div>
      </article>

      <article class="glass-card p-10">
        <h2 class="text-3xl font-black uppercase mb-6 tracking-tight text-blue-600 dark:text-blue-400">Educación</h2>
        <div class="space-y-6">
          <div class="relative pl-6 border-l-2 border-blue-500/20">
            <h3 class="text-lg font-bold uppercase">UTN FRRE</h3>
            <p class="text-sm opacity-60 uppercase">Tecnicatura Universitaria en Programación</p>
          </div>
        </div>
      </article>
    </div>
  </div>
</Layout>