---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets'; 

const habilidades = ["ASTRO", "TAILWIND", "SVELTE", "TYPESCRIPT", "JAVA", "KALI LINUX"];
---

<Layout title="Juan Cruz Cabrera | Portfolio">
  <div class="mx-auto max-w-6xl px-6 page-container">
    
    <section class="cv-card p-10 md:p-14 relative overflow-hidden">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-600/10 blur-[120px] rounded-full"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
        <div class="relative">
          <div class="absolute inset-0 bg-blue-500 blur-3xl opacity-20"></div>
          <Image src="/juan-cabrera.jpg" alt="Juan Cruz Cabrera" width={280} height={280} class="relative rounded-[3rem] border-2 border-white shadow-2xl"/>
        </div>

        <div class="flex-1 text-center md:text-left">
          <p class="text-blue-600 font-black tracking-[0.5em] text-sm uppercase mb-4">Programador</p>
          <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-[0.9] mb-8 text-main-title uppercase">
            JUAN CRUZ <br/> CABRERA
          </h1>
          <p class="text-2xl opacity-90 font-medium leading-relaxed">
            Especializado en arquitecturas modernas con <span class="text-blue-600 font-bold">Astro</span>. Estudiante de la <span class="font-bold text-main-title">UTN</span>.
          </p>
        </div>
      </div>

      <div class="mt-10 flex flex-wrap gap-4 justify-center md:justify-start">
        {habilidades.map((h) => <span class="skill-tag">{h}</span>)}
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-6 justify-center md:justify-start">
        <a href="/personal" class="btn-primary">Información Personal</a>
        
        <a href="https://github.com/DJsexum" target="_blank" class="btn-icon btn-github-icon" title="GitHub">
          <svg viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>

        <a href="https://linkedin.com/in/tu-usuario" target="_blank" class="btn-icon btn-linkedin-icon" title="LinkedIn">
          <svg viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-4">
      
      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">Proyectos</h2>
        <div class="space-y-6">
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="text-xl font-bold uppercase text-main-title italic">TechStore</h3>
            <p class="text-base opacity-70">Implementación de bases de datos SQL normalizadas y reportes detallados para gestión comercial.</p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="text-xl font-bold uppercase text-main-title italic">LaMasita</h3>
            <p class="text-base opacity-70">Herramienta de automatización de mensajería desarrollada en Python utilizando Tkinter y PyAutoGUI.</p>
          </div>
        </div>
      </article>

      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">Educación</h2>
        <div class="pl-6 border-l-4 border-slate-200">
          <h3 class="text-xl font-bold uppercase text-main-title italic">UTN (Universidad Tecnológica Nacional)</h3>
          <p class="text-base opacity-70 uppercase font-medium">Tecnicatura Universitaria en Programación.</p>
          <p class="mt-2 text-sm opacity-60">Foco en Bases de Datos II, Programación III y Probabilidad/Estadística.</p>
        </div>
      </article>

    </div>
  </div>
</Layout>