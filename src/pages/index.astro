---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets'; 

const habilidades = ["ASTRO", "TAILWIND", "SVELTE", "TYPESCRIPT", "JAVA", "KALI LINUX"];
---

<Layout title="Juan Cruz Cabrera | Portfolio">
  <div class="mx-auto max-w-6xl px-6 h-screen flex flex-col justify-evenly py-8">
    
    <section class="cv-card p-10 md:p-14 relative overflow-hidden">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-600/10 blur-[120px] rounded-full"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
        <div class="relative">
          <div class="absolute inset-0 bg-blue-500 blur-3xl opacity-20"></div>
          <Image 
            src="/juan-cabrera.jpg" 
            alt="Juan Cruz Cabrera" 
            width={280} 
            height={280} 
            class="relative rounded-[3rem] border-2 border-white shadow-2xl"
          />
        </div>

        <div class="flex-1 text-center md:text-left">
          <p class="text-blue-600 font-black tracking-[0.5em] text-sm uppercase mb-4">Programador</p>
          <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-[0.9] mb-8 text-main-title uppercase">
            JUAN CRUZ <br/> CABRERA
          </h1>
          <p class="text-2xl opacity-90 max-w-xl font-medium leading-relaxed">
            Especializado en arquitecturas modernas con <span class="text-blue-600 font-bold">Astro</span> y ciberseguridad. Estudiante de la <span class="font-bold text-main-title">UTN</span>.
          </p>
        </div>
      </div>

      <div class="mt-10 flex flex-wrap gap-4 justify-center md:justify-start">
        {habilidades.map((h) => (
          <span class="skill-tag">{h}</span>
        ))}
      </div>

      <div class="mt-10 flex flex-wrap gap-6 justify-center md:justify-start">
        <a href="/personal" class="px-12 py-6 bg-blue-600 text-white font-black rounded-2xl hover:bg-blue-700 transition-all uppercase text-sm tracking-widest shadow-xl shadow-blue-600/20">
          Información Personal
        </a>
        <a href="https://github.com/DJsexum" target="_blank" class="px-12 py-6 bg-slate-900 text-white font-black rounded-2xl hover:bg-slate-800 transition-all uppercase text-sm tracking-widest shadow-xl">
          Mi GitHub
        </a>
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">Proyectos</h2>
        <div class="space-y-6">
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="text-xl font-bold uppercase text-main-title italic">TechStore</h3>
            <p class="text-base opacity-70">Bases de datos SQL corregidas y normalizadas.</p>
          </div>
          <div class="pl-6 border-l-4 border-slate-200">
            <h3 class="text-xl font-bold uppercase text-main-title italic">LaMasita</h3>
            <p class="text-base opacity-70">Automatización con Python y PyAutoGUI.</p>
          </div>
        </div>
      </article>

      <article class="cv-card p-10">
        <h2 class="text-3xl font-black uppercase mb-8 text-blue-600">Educación</h2>
        <div class="pl-6 border-l-4 border-slate-200">
          <h3 class="text-xl font-bold uppercase text-main-title italic">UTN</h3>
          <p class="text-base opacity-70 uppercase font-medium">Tecnicatura Universitaria en Programación.</p>
        </div>
      </article>
    </div>
  </div>
</Layout>